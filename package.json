{
  "name": "agentic-mcp-teaming",
  "version": "0.1.0",
  "description": "Claude + Codex teaming coordinator via MCP",
  "type": "module",
  "bin": {
    "coordinator": "dist/index.js"
  },
  "files": [
    "dist",
    "mcp-config.json",
    "readme.md"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "serve": "bash scripts/clean-stale-sessions.sh && tsx src/index.ts serve",
    "build": "tsc && chmod +x dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.0"
  }
}
